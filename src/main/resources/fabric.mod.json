{
  "schemaVersion": 1,
  "id": "trevoraddons",
  "version": "${version}",
  "name": "TrevorAddons",
  "description": "Client-side Fabric mod for SkyBlock Trevor hunting with ESP, tracers, presets, and an in-game editor.",
  "authors": [
    "r4yen"
  ],
  "contact": {
    "homepage": "https://github.com/r4yen/TrevorAddons",
    "sources": "https://github.com/r4yen/TrevorAddons",
    "issues": "https://discord.gg/8kMmj8Vb9Q"
  },
  "license": "All-Rights-Reserved",
  "icon": "logo.png",
  "environment": "client",
  "entrypoints": {
    "fabric-datagen": [
      "cc.rayen.trevoraddons.client.TrevorAddonsDataGenerator"
    ],
    "client": [
      "cc.rayen.trevoraddons.client.TrevorAddonsClient"
    ],
    "modmenu": [
      "cc.rayen.trevoraddons.client.TrevorAddonsModMenu"
    ],
    "main": [
      "cc.rayen.trevoraddons.TrevorAddons"
    ]
  },
  "custom": {
    "modmenu": {
      "links": {
        "trevoraddons.discord": "https://discord.gg/8kMmj8Vb9Q",
        "trevoraddons.github": "https://github.com/r4yen/TrevorAddons",
        "trevoraddons.issues": "https://discord.gg/8kMmj8Vb9Q"
      }
    }
  },
  "mixins": [
    "trevoraddons.mixins.json",
    {
      "config": "trevoraddons.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": "${loader_version_range}",
    "fabric-api": ">=${fabric_version}",
    "minecraft": "${minecraft_version_range}"
  }
}
